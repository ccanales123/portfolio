---
// src/components/ValueProps.astro
import type { Translations } from '../i18n/en';

interface Props { t: Translations; }
const { t } = Astro.props;

const values = [
  { icon: '<path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>', title: t.value.v1t, desc: t.value.v1d },
  { icon: '<rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/>', title: t.value.v2t, desc: t.value.v2d },
  { icon: '<path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/>', title: t.value.v3t, desc: t.value.v3d },
  { icon: '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>', title: t.value.v4t, desc: t.value.v4d },
  { icon: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>', title: t.value.v5t, desc: t.value.v5d },
  { icon: '<circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/>', title: t.value.v6t, desc: t.value.v6d },
];
---
<section class="section-alt" id="value">
  <div class="reveal">
    <div class="section-label">{t.value.label}</div>
    <h2 class="section-title">{t.value.title}</h2>
  </div>
  <div class="value-grid stagger-children">
    {values.map(v => (
      <div class="value-card reveal tilt-card card-spotlight">
        <div class="spotlight"></div>
        <div class="value-icon"><svg viewBox="0 0 24 24" set:html={v.icon} /></div>
        <h3 class="value-title">{v.title}</h3>
        <p class="value-desc">{v.desc}</p>
      </div>
    ))}
  </div>
</section>
<div class="section-divider"></div>
